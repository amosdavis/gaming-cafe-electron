<?xml version="1.0" encoding="utf-8"?>
<!--
  Gaming Cafe Kiosk — Windows 11 Unattended Answer File
  Provides fully automated, zero-prompt Windows 11 installation.

  Disk layout (UEFI/GPT):
    Partition 1: System (EFI)  100 MB
    Partition 2: MSR           16 MB
    Partition 3: Windows       remainder

  Customise before use:
    - Replace __KIOSK_PASSWORD__ with the desired KioskAdmin account password
      (the GitHub Actions workflow substitutes this from the KIOSK_PASSWORD secret)
    - TimeZone, UILanguage, SystemLocale, UserLocale can be adjusted as needed

  CI: QEMU uses Q35 machine + ich9-ahci CDROM (bootindex=1) for OVMF UEFI boot compatibility.
  CI: startup.nsh is now baked into the ISO root (UDF volume) for EFI Shell auto-boot (r9).
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ═══════════════════════════════════════════════════════════════════════
       PASS 1 — windowsPE  (runs inside WinPE before Windows is installed)
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="windowsPE">

    <!-- Language / keyboard for the setup UI -->
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <!-- Disk partitioning and Windows image selection -->
    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!-- TPM / Secure Boot bypass for evaluation / dedicated hardware -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <!-- EFI System Partition -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>100</Size>
            </CreatePartition>
            <!-- Microsoft Reserved Partition -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <!-- Windows OS Partition (remainder of disk) -->
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>System</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Format>NTFS</Format>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <!-- Index 1 = Windows 11 Enterprise Evaluation -->
            <MetaData wcm:action="add">
              <Key>/IMAGE/INDEX</Key>
              <Value>1</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <UserData>
        <!-- No product key for evaluation; accept EULA automatically -->
        <AcceptEula>true</AcceptEula>
        <FullName>Kiosk</FullName>
        <Organization>Gaming Cafe</Organization>
      </UserData>

    </component>
  </settings>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PASS 4 — specialize  (first boot after imaging, machine-specific config)
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="specialize">

    <!--
      Copy kiosk installer and setup script from installation media.
      $OEM$\$1\ file injection is unreliable with WillWipeDisk=true in Windows 11;
      this RunSynchronous command finds the still-mounted ISO drive and copies
      \KioskSetup\ to C:\KioskSetup\ and setup-complete.cmd to the Setup\Scripts
      location where Windows Setup will run it natively on first boot.
    -->
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <WillReboot>Never</WillReboot>
          <Path>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$d=(Get-Volume | Where-Object { $_.DriveLetter -and (Test-Path ($_.DriveLetter+':\KioskSetup\GamingCafeKiosk-Setup.exe')) } | Select-Object -First 1 -ExpandProperty DriveLetter); if($d){ Copy-Item ($d+':\KioskSetup') C:\KioskSetup -Recurse -Force; New-Item -ItemType Directory -Path C:\Windows\Setup\Scripts -Force | Out-Null; Copy-Item ($d+':\KioskSetup\setup-complete.cmd') C:\Windows\Setup\Scripts\SetupComplete.cmd -Force }"</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <WillReboot>Never</WillReboot>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE" /v BypassNRO /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <ComputerName>GamingCafeKiosk</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>

    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>
  </settings>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PASS 7 — oobeSystem  (Out-of-Box Experience — skip all screens)
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <!-- Create local KioskAdmin account (password substituted by CI) -->
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>KioskAdmin</Name>
            <DisplayName>Kiosk Admin</DisplayName>
            <Group>Administrators</Group>
            <Password>
              <Value>__KIOSK_PASSWORD__</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>KioskAdmin</Username>
        <Password>
          <Value>__KIOSK_PASSWORD__</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>999</LogonCount>
      </AutoLogon>

    </component>
  </settings>

</unattend>
