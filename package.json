{
  "name": "gaming-cafe-electron",
  "version": "1.0.0",
  "description": "Gaming Cafe Kiosk – Electron + React",
  "main": "out/main/index.js",
  "scripts": {
    "dev":   "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist":  "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer":         "^10.4.18",
    "electron":             "^29.1.0",
    "electron-builder":     "^24.12.0",
    "electron-vite":        "^2.1.0",
    "postcss":              "^8.4.35",
    "react":                "^18.2.0",
    "react-dom":            "^18.2.0",
    "tailwindcss":          "^3.4.1"
  },
  "build": {
    "appId":       "com.gamingcafe.kiosk",
    "productName": "Gaming Cafe Kiosk",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon":   "resources/icon.ico"
    },
    "files": ["out/**/*", "resources/**/*"]
  }
}
